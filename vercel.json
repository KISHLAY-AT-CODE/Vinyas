{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/templates.js": {
      "includeFiles": "templates/**"
    },
    "api/data.js": {
      "includeFiles": "templates/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/src/(.*)",
      "destination": "/src/$1"
    },
    {
      "source": "/node_modules/(.*)",
      "destination": "/node_modules/$1"
    },
    {
      "source": "/@vite/(.*)",
      "destination": "/@vite/$1"
    },
    {
      "source": "/@react-refresh(.*)",
      "destination": "/@react-refresh$1"
    },
    {
      "source": "/((?!api|src|node_modules|@vite|@react-refresh|assets|favicon.ico|icon.png|icon.svg|icon_alt.svg|manifest.json).*)",
      "destination": "/index.html"
    }
  ]
}