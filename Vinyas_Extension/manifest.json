{
  "manifest_version": 3,
  "name": "Vinyas Tracker",
  "version": "2.1.0",
  "description": "Tracks PW activity and syncs it to Vinyas Dashboard",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.pw.live/*",
    "*://pw.live/*",
    "*://*.physicswallah.live/*",
    "*://physicswallah.live/*",
    "http://localhost:3000/*",
    "https://*.vercel.app/*"
  ],
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.pw.live/*",
        "*://pw.live/*",
        "*://*.physicswallah.live/*",
        "*://physicswallah.live/*"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://*.vercel.app/*"
      ],
      "js": [
        "dashboard_connector.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "favicon.ico"
      ],
      "matches": [
        "*://*.pw.live/*",
        "*://pw.live/*",
        "*://*.physicswallah.live/*",
        "*://physicswallah.live/*"
      ]
    }
  ]
}
