                dialog.destroy()
            
        btn = tk.Button(dialog, text="Add Subject", command=on_ok, bg="#0d9488", fg="#f8fafc", activebackground="#14b8a6", activeforeground="#f8fafc", relief="flat", font=("Segoe UI", 9, "bold"), padx=10, pady=3)
