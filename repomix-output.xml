  0% { transform: translateY(20px) scale(0) rotate(0deg); opacity: 0; }
  20% { opacity: 0.85; }
  80% { opacity: 0.6; }
  100% { transform: translateY(-40px) scale(1.1) rotate(120deg); opacity: 0; }
