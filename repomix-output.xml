                </div>

                {/* Multplier Rule hint */}
                <div className="text-[10px] text-slate-500 text-center font-semibold mt-3 italic">
                    🔥 Maintain a 3-day streak for 1.2x XP, or 7-day for 1.5x XP!
                </div>
            </div>
        </div>
    );
};

