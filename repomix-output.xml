  --primary-accent-glow: rgba(249, 115, 22, 0.18);
  --primary-accent-hover: #ea580c;
  --secondary-accent: #ec4899;
  --secondary-accent-rgb: 236, 72, 153;
  
  /* Redesigned Premium Customizer Variables */
  --glass-opacity: 0.25;
  --glass-blur: 100px;
  --header-backdrop: rgba(15, 23, 42, 0.65);
  --card-backdrop: rgba(10, 15, 30, 0.4);
  --hover-border-glow: #f97316;
  --body-bg-color: #0f172a;
}

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  body { 
    background-color: var(--body-bg-color, #0f172a) !important; 
    font-family: 'Poppins', 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; 
    scroll-behavior: smooth; 
  }
}

@layer utilities {
  .glass { 
    background: rgba(30, 41, 59, 0.7); 
    backdrop-filter: blur(10px); 
    border: 1px solid rgba(255, 255, 255, 0.1); 
  }

  /* Dynamic Theme Utilities */
  .theme-text { color: var(--primary-accent) !important; }
  .theme-bg { background-color: var(--primary-accent) !important; }
  .theme-border { border-color: var(--primary-accent) !important; }
  .theme-border-glow { border-color: rgba(var(--primary-accent-rgb), 0.4) !important; }
  .theme-glow { box-shadow: 0 0 15px var(--primary-accent-glow) !important; }
  .theme-gradient-bg { background: linear-gradient(to right, var(--primary-accent), var(--secondary-accent)) !important; }
  .theme-gradient-text {
    background: linear-gradient(to right, var(--primary-accent), var(--secondary-accent)) !important;
    -webkit-background-clip: text !important;
    -webkit-text-fill-color: transparent !important;
    background-clip: text !important;
  }
  
  .glass-card {
    background: var(--card-backdrop) !important;
    backdrop-filter: blur(calc(var(--glass-blur, 100px) * 0.15)) !important;
    -webkit-backdrop-filter: blur(calc(var(--glass-blur, 100px) * 0.15)) !important;
    border: 1px solid rgba(var(--hover-border-glow-rgb, 255, 255, 255), 0.15) !important;
    box-shadow: 0 12px 40px 0 rgba(0, 0, 0, calc(var(--glass-opacity, 0.25) * 0.55)), inset 0 1px 1px rgba(255, 255, 255, 0.08) !important;
    border-radius: 1rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
  }
  
  .glass-card:hover {
    border-color: rgba(var(--hover-border-glow-rgb, 249, 115, 22), 0.45) !important;
    box-shadow: 0 12px 40px 0 rgba(var(--hover-border-glow-rgb, 249, 115, 22), 0.15) !important;
  }

  /* Sidebar hover micro-animations */
  .group:hover .hover-wiggle {
    animation: flameWiggle 0.18s infinite ease-in-out;
  }
  .group:hover .hover-spin-slow {
    transform: rotate(360deg);
    transition: transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .group:hover .hover-pulse-fast {
    animation: pulse 1s infinite ease-in-out;
  }
  .group:hover .hover-bounce-sm {
    animation: bounce 1s infinite;
  }
  .group:hover .hover-scale-up {
    transform: scale(1.2);
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .group:hover .hover-rotate-gear {
    transform: rotate(90deg);
    transition: transform 0.4s ease-out;
  }
  .group:hover .hover-shake {
    animation: hoverShakeKey 0.5s ease-in-out infinite;
  }
  
  @keyframes hoverShakeKey {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(-8deg); }
    75% { transform: rotate(8deg); }
  }

  
  .hover-fire:hover {
    background: rgba(30, 41, 59, 0.6) !important;
    border-color: rgba(249, 115, 22, 0.3) !important;
    box-shadow: 0 0 30px rgba(249, 115, 22, 0.12) !important;
  }
  
  .hover-syllabus:hover {
    background: rgba(30, 41, 59, 0.6) !important;
    border-color: rgba(139, 92, 246, 0.3) !important;
    box-shadow: 0 0 30px rgba(139, 92, 246, 0.12) !important;
  }
  
  .hover-streak:hover {
    background: rgba(30, 41, 59, 0.6) !important;
    border-color: rgba(16, 185, 129, 0.3) !important;
    box-shadow: 0 0 30px rgba(16, 185, 129, 0.12) !important;
  }
  
  .hover-goals:hover {
    background: rgba(30, 41, 59, 0.6) !important;
    border-color: rgba(234, 179, 8, 0.3) !important;
    box-shadow: 0 0 30px rgba(234, 179, 8, 0.12) !important;
  }
  
  .hover-routine:hover {
    background: rgba(30, 41, 59, 0.6) !important;
    border-color: rgba(59, 130, 246, 0.3) !important;
    box-shadow: 0 0 30px rgba(59, 130, 246, 0.12) !important;
  }
  
  .hover-timer:hover {
    background: rgba(30, 41, 59, 0.6) !important;
    border-color: rgba(14, 165, 233, 0.3) !important;
    box-shadow: 0 0 30px rgba(14, 165, 233, 0.12) !important;
  }
  
  .hover-spaced:hover {
    background: rgba(30, 41, 59, 0.6) !important;
    border-color: rgba(168, 85, 247, 0.3) !important;
    box-shadow: 0 0 30px rgba(168, 85, 247, 0.12) !important;
  }
  
  .hover-achievements:hover {
    background: rgba(30, 41, 59, 0.6) !important;
    border-color: rgba(245, 158, 11, 0.3) !important;
    box-shadow: 0 0 30px rgba(245, 158, 11, 0.12) !important;
  }
  
  
  .table-input { 
    width: 100%; 
    background: transparent; 
    text-align: right; 
    outline: none; 
    border-bottom: 1px solid transparent; 
    transition: all 0.2s; 
  }
  
  .table-input:focus { 
    border-bottom: 1px solid #38bdf8; 
  }
  
  .table-input::-webkit-outer-spin-button, 
  .table-input::-webkit-inner-spin-button { 
    -webkit-appearance: none; 
    margin: 0; 
  }

  .text-fire {
    background: linear-gradient(to top, #3b82f6 0%, #ef4444 30%, #f97316 60%, #fde047 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }
  
  .modal-animate { 
    animation: fadeInScale 0.2s ease-out forwards; 
  }

  .highlight-row { 
    animation: highlightFade 3s ease-out forwards; 
  }
}

/* Custom Scrollbar */
::-webkit-scrollbar { width: 6px; height: 6px; }
