/* Rising background fill container */
.row-fill-container {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  overflow: hidden;
  z-index: 0;
  opacity: 0;
  transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

tr:hover .row-fill-container {
  opacity: 1;
}

/* Rising color wave */
.row-fill-wave {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  width: 100%;
  height: 0;
  transition: height 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  z-index: 0;
}

tr:hover .row-fill-wave {
  height: 100%;
}

/* Waves themes */
.chapter-row-emerald:hover .row-fill-wave {
  background: linear-gradient(to top, rgba(16, 185, 129, 0.14) 0%, rgba(16, 185, 129, 0.04) 70%, transparent 100%);
}

.chapter-row-yellow:hover .row-fill-wave {
  background: linear-gradient(to top, rgba(250, 204, 21, 0.14) 0%, rgba(250, 204, 21, 0.04) 70%, transparent 100%);
}

.chapter-row-red:hover .row-fill-wave {
  background: linear-gradient(to top, rgba(239, 68, 68, 0.14) 0%, rgba(239, 68, 68, 0.04) 70%, transparent 100%);
}

.chapter-row-white:hover .row-fill-wave {
  background: linear-gradient(to top, rgba(255, 255, 255, 0.10) 0%, rgba(255, 255, 255, 0.02) 70%, transparent 100%);
}

